{
  "manifest_version": 3,
  "name": "YTM-Immersion",
  "version": "1.1.0",
  "description": "YouTube Musicをもっと美しく",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://music.youtube.com/*",
    "https://lrclib.net/*",
    "https://lrchub.coreone.work/*",
    "http://lrchub.coreone.work/*",
    "https://immersionproject.coreone.work/*",
    "http://immersionproject.coreone.work/*",
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "http://127.0.0.1:5678/*",
    "http://localhost:5678/*",
    "https://raw.githubusercontent.com/*",
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "src/js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://music.youtube.com/*"
      ],
      "js": [
        "src/js/modules/core/constants.js",
        "src/js/modules/core/config.js",
        "src/js/modules/core/state.js",
        "src/js/modules/services/storage.js",
        "src/js/modules/services/i18n.js",
        "src/js/modules/features/progressHandle.js",
        "src/js/modules/features/replayManager.js",
        "src/js/modules/features/queueManager.js",
        "src/js/modules/features/pipManager.js",
        "src/js/modules/services/cloudSync.js",
        "src/js/modules/lyrics/lyricsParser.js",
        "src/js/modules/services/translation.js",
        "src/js/modules/ui/uiRendering.js",
        "src/js/modules/ui/uiManager.js",
        "src/js/modules/lyrics/lyricsLoader.js",
        "src/js/modules/core/events.js",
        "src/js/modules/features/discordPresence.js",
        "src/js/modules/features/share.js",
        "src/js/modules/features/movieMode.js",
        "src/js/content.js"
      ],
      "css": [
        "src/css/style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/fonts/*.woff2"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  }
}